{
  "info": {
    "name": "Auth Demo - Authentication Flow",
    "description": "Example requests for the authentication demo API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Register New User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"john_doe\",\n  \"password\": \"mySecurePassword123\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/register",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["register"]
        }
      },
      "description": "Create a new user account. Username must be unique."
    },
    {
      "name": "2. Login (Get Token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"john_doe\",\n  \"password\": \"mySecurePassword123\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["login"]
        }
      },
      "description": "Login with username and password. Returns a JWT token that expires in 1 hour. Copy the token value for the next request."
    },
    {
      "name": "3. Access Protected Route (Profile)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer YOUR_TOKEN_HERE",
            "description": "Replace YOUR_TOKEN_HERE with the token from the Login response"
          }
        ],
        "url": {
          "raw": "http://localhost:3000/profile",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["profile"]
        }
      },
      "description": "Access the protected profile route. Requires a valid JWT token in the Authorization header. Format: 'Bearer <token>'"
    },
    {
      "name": "4. View All Users (Public)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/users",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["users"]
        }
      },
      "description": "View all registered users. This is a public endpoint (no token needed)."
    },
    {
      "name": "5. Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": [""]
        }
      },
      "description": "Simple endpoint to verify the server is running."
    }
  ]
}
